# 复制此文件为 .env 并填入真实 Key
# cp .env.example .env

# DeepSeek API Key（https://platform.deepseek.com）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 高德地图 Web 服务 Key（后端调用路线/搜索 API）
# 在高德控制台创建「Web 服务」类型应用获取
# https://console.amap.com
AMAP_KEY=your_amap_web_service_key_here

# 高德地图 JS API Key（前端地图渲染）
# 在高德控制台创建「Web 端（JS API）」类型应用获取
# 需在控制台将 localhost 和 127.0.0.1 加入域名白名单
AMAP_JS_KEY=your_amap_js_api_key_here
